# Environment Configuration Template
# Copy this to .env and update with your values

# ============ DATABASE ============
DB_NAME=fraud_detection
DB_USER=postgres
DB_PASSWORD=change_me
DB_HOST=localhost
DB_PORT=5432

# ============ SPRING BOOT ============
SERVER_PORT=8080
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/fraud_detection
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# ============ JWT ============
JWT_SECRET=change_me_in_production
JWT_EXPIRATION=86400000

# ============ FLASK AI SERVICE ============
FLASK_PORT=5000
FLASK_ENV=development
AI_MODEL_URL=http://localhost:5000/predict

# ============ CORS ============
CORS_ORIGIN_1=http://localhost:5173
CORS_ORIGIN_2=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# ============ LOGGING ============
LOG_LEVEL=DEBUG
LOGGING_LEVEL_COM_EXAMPLE_FRAUDDETECTIONSYSTEM=DEBUG

